        return
    end
    
    local ui = QTEHandler.Elements
    if not ui or not ui.needle or not ui.target then
        QTE_StopMonitoring()
        return
    end
    
    if QTE_IsNeedleInZone(ui.needle.Rotation, ui.target.Rotation) then
        QTE_SimulateInput()
        QTE_StopMonitoring()
    end
